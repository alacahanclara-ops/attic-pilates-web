---
const base = import.meta.env.BASE_URL;

const fotos = [
  { src: `${base}espacio/1.jpg`,  alt: 'Attic Pilates' },
  { src: `${base}espacio/2.jpg`,  alt: 'Attic Pilates' },
  { src: `${base}espacio/3.jpg`,  alt: 'Attic Pilates' },
  { src: `${base}espacio/4.jpg`,  alt: 'Attic Pilates' },
  { src: `${base}espacio/5.jpg`,  alt: 'Attic Pilates' },
  { src: `${base}espacio/6.jpg`,  alt: 'Attic Pilates' },
  { src: `${base}espacio/7.jpg`,  alt: 'Attic Pilates' },
  { src: `${base}espacio/8.jpg`,  alt: 'Attic Pilates' },
  { src: `${base}espacio/9.jpg`,  alt: 'Attic Pilates' },
  { src: `${base}espacio/10.jpg`, alt: 'Attic Pilates' },
  { src: `${base}espacio/11.jpg`, alt: 'Attic Pilates' },
  { src: `${base}espacio/12.jpg`, alt: 'Attic Pilates' },
  { src: `${base}espacio/13.jpg`, alt: 'Attic Pilates' },
];
---

<section class="espacio section" id="espacio">
  <div class="container">
    <div class="espacio-header">
      <p class="subtitle">El lugar</p>
      <h2>Nuestro Espacio<br /><em>& Comunidad</em></h2>
    </div>
  </div>

  <div class="carrusel-wrapper">
    <div class="carrusel-track" id="carrusel-track">
      {fotos.map((foto) => (
        <div class="carrusel-slide">
          <img src={foto.src} alt={foto.alt} loading="eager" />
        </div>
      ))}
      {/* Duplicado para loop infinito */}
      {fotos.map((foto) => (
        <div class="carrusel-slide" aria-hidden="true">
          <img src={foto.src} alt="" loading="eager" />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .espacio-header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .espacio-header h2 {
    line-height: 1.2;
  }

  .espacio-header h2 em {
    font-style: italic;
    font-weight: 300;
    color: var(--color-taupe);
  }

  .carrusel-wrapper {
    overflow: hidden;
    width: 100%;
  }

  .carrusel-track {
    display: flex;
    gap: 1rem;
    animation: slide 28s linear infinite;
    width: max-content;
  }

  .carrusel-wrapper:hover .carrusel-track {
    animation-play-state: paused;
  }

  .carrusel-slide {
    flex-shrink: 0;
    width: 420px;
    height: 560px;
    border-radius: var(--border-radius-lg);
    overflow: hidden;
  }

  .carrusel-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .carrusel-slide:hover img {
    transform: scale(1.03);
  }

  @keyframes slide {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (max-width: 768px) {
    .carrusel-slide {
      width: 300px;
      height: 400px;
    }
  }
</style>
