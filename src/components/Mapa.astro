---
const mapsUrl = 'https://www.google.com/maps/place/ATTIC+-+Pilates+%26+Barre+Studio/@-34.589949,-58.431198,17z/data=!3m1!4b1!4m6!3m5!1s0x95bcb5449fb1ca3f:0xc6b03768ea4411dd!8m2!3d-34.5899534!4d-58.4286231!16s%2Fg%2F11xst1bsfx?entry=ttu&g_ep=EgoyMDI2MDYwOS4wIKXMDSoASAFQAw%3D%3D';
const embedSrc = 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3283.8!2d-58.4286231!3d-34.5899534!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95bcb5449fb1ca3f%3A0xc6b03768ea4411dd!2sATTIC%20-%20Pilates%20%26%20Barre%20Studio!5e0!3m2!1ses!2sar!4v1749742600000!5m2!1ses!2sar';
---

<section class="mapa section" id="ubicacion">
  <div class="container">
    <div class="mapa-header">
      <p class="subtitle">Cómo llegar</p>
      <h2><a href={mapsUrl} target="_blank" rel="noopener" style="color: inherit; text-decoration: none;">Honduras 4822</a><br /><em>Palermo Soho</em></h2>
      <a href={mapsUrl} target="_blank" rel="noopener" class="mapa-link">
        Abrir en Google Maps
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
      </a>
    </div>
  </div>

  <div class="mapa-wrapper">
    <iframe
      src={embedSrc}
      title="Mapa Attic Pilates — Honduras 4822, Palermo Soho"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      allowfullscreen
    ></iframe>
  </div>
</section>

<style>
  .mapa-header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .mapa-header .subtitle {
    justify-content: center;
  }

  .mapa-header .subtitle::before {
    display: none;
  }

  .mapa-header h2 {
    line-height: 1.2;
    margin-bottom: var(--space-md);
  }

  .mapa-header h2 em {
    font-style: italic;
    font-weight: 300;
    color: var(--color-taupe);
  }

  .mapa-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-dark);
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    transition: gap var(--transition);
  }

  .mapa-link:hover {
    gap: 0.7rem;
  }

  .mapa-wrapper {
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  .mapa-wrapper iframe {
    width: 100%;
    height: 420px;
    border: 0;
    border-radius: var(--border-radius-lg);
    filter: grayscale(0.25) contrast(1.02);
    transition: filter var(--transition);
  }

  .mapa-wrapper iframe:hover {
    filter: grayscale(0) contrast(1);
  }

  @media (max-width: 768px) {
    .mapa-wrapper iframe {
      height: 320px;
    }
  }
</style>
