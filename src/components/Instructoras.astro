---
const BASE = import.meta.env.BASE_URL;

const instructores = [
  {
    nombre: 'Male',
    rol: 'Instructora de Pilates Clásico',
    foto: null,
    bio: 'Sus clases tienen una impronta clásica y técnica, con foco en la precisión, el control y la correcta ejecución de cada movimiento. Especializada en prevención y rehabilitación de lesiones y patologías, trabaja desde un abordaje consciente y personalizado que busca fortalecer el cuerpo desde la base y mejorar la movilidad, estabilidad y postura.',
  },
  {
    nombre: 'Lore',
    rol: 'Instructora de Pilates, Barre & Cadillac',
    foto: null,
    bio: 'Sus clases son dinámicas, intensas y súper variadas. Desde un enfoque contemporáneo, combina fuerza, coordinación y resistencia con secuencias creativas que cambian constantemente, logrando que cada clase se sienta desafiante, divertida y llena de energía. Su estilo cercano y motivador impulsa a cada alumno a explorar sus límites mientras desarrolla mayor control y confianza en el movimiento.',
  },
  {
    nombre: 'Cami',
    rol: 'Instructora de Pilates & Cadillac',
    foto: null,
    bio: 'Sus clases combinan fuerza, movilidad y control corporal con una energía cálida y cercana. Tiene un fuerte enfoque en Cadillac y trabajo aéreo, integrando ejercicios dinámicos y fluidos que desafían el cuerpo de manera consciente. Acompaña a cada alumno de forma personalizada y amorosa, creando un espacio de confianza donde el movimiento se vive con disfrute, seguridad y conexión.',
  },
  {
    nombre: 'Eros',
    rol: 'Instructor de Pilates & Alto Rendimiento',
    foto: null,
    bio: 'Sus clases tienen un enfoque fuerte en el trabajo muscular, la estabilidad y el rendimiento físico. Ex jugador de Los Pumitas y formado junto a la UAR en entrenamiento de alto rendimiento, combina intensidad, resistencia y técnica de movimiento en propuestas dinámicas inspiradas en distintas disciplinas deportivas.',
  },
  {
    nombre: 'Nacho',
    rol: 'Instructor de Pilates & Yoga',
    foto: null,
    bio: 'Sus clases integran movilidad, fuerza y conciencia corporal desde un enfoque funcional y contemporáneo. Con herramientas provenientes tanto del yoga como del entrenamiento deportivo, propone clases fluidas y desafiantes que combinan coordinación, respiración y trabajo profundo del cuerpo para potenciar el bienestar y el rendimiento físico.',
  },
  {
    nombre: 'Flor',
    rol: 'Instructora de Pilates Clásico',
    foto: null,
    bio: 'Sus clases están orientadas al Pilates clásico, con foco en la técnica, la fuerza y la conciencia corporal. Con más de 10 años de experiencia, propone secuencias sólidas y desafiantes que trabajan el cuerpo de manera integral, ayudando a desarrollar estabilidad, movilidad y control desde un enfoque preciso y consciente del movimiento.',
  },
];
---

<section class="section instructoras" id="nosotros">
  <div class="container">
    <div class="instructoras-header">
      <p class="subtitle">Nuestro equipo</p>
      <h2>El equipo hace la diferencia</h2>
      <p class="instructoras-desc">
        La calidad de los instructores es el diferenciador central de Attic.
        Cada clase está diseñada y guiada por profesionales con formación técnica y pasión por el movimiento.
      </p>
    </div>

    <div class="profes-grid">
      {instructores.map((p) => (
        <div class="profe-card">
          <div class="profe-foto">
            {p.foto
              ? <img src={p.foto} alt={p.nombre} loading="lazy" />
              : <span class="profe-inicial">{p.nombre[0]}</span>
            }
          </div>
          <div class="profe-info">
            <h3>{p.nombre}</h3>
            <p class="profe-rol">{p.rol}</p>
            <p class="profe-bio">{p.bio}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .instructoras-header {
    text-align: center;
    margin-bottom: var(--space-xl);
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .instructoras-header h2 {
    margin-bottom: var(--space-sm);
  }

  .instructoras-desc {
    font-size: 0.95rem;
    color: var(--color-text-soft);
    line-height: 1.75;
    margin-top: var(--space-sm);
  }

  .profes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .profe-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-lg);
    border: 1px solid rgba(45, 41, 38, 0.08);
    border-radius: var(--radius);
    transition: box-shadow 0.25s ease;
  }

  .profe-card:hover {
    box-shadow: 0 4px 20px rgba(45, 41, 38, 0.08);
  }

  .profe-foto {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: var(--color-taupe);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-md);
    overflow: hidden;
    flex-shrink: 0;
  }

  .profe-foto img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .profe-inicial {
    font-size: 2rem;
    font-weight: 300;
    color: var(--color-cream);
    line-height: 1;
  }

  .profe-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .profe-card h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-dark);
  }

  .profe-rol {
    font-size: 0.75rem;
    color: var(--color-taupe);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .profe-bio {
    font-size: 0.82rem;
    color: var(--color-text-soft);
    line-height: 1.7;
    text-align: left;
  }

  @media (max-width: 900px) {
    .profes-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .profes-grid {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .profe-card {
      flex-direction: row;
      text-align: left;
      align-items: flex-start;
      gap: var(--space-md);
      padding: var(--space-md);
    }

    .profe-foto {
      width: 64px;
      height: 64px;
      margin-bottom: 0;
    }

    .profe-inicial {
      font-size: 1.4rem;
    }
  }
</style>
